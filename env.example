# ──────────────────────────────────────────────────────────────────────────
# Ugin's Vault backend — environment template
# Copy to `.env` for local runs (`cp env.example .env`). Never commit real keys.
# ──────────────────────────────────────────────────────────────────────────

# Supabase project (Settings -> API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Publishable / anon key — used ONLY to verify incoming JWTs (getClaims).
# Safe to expose; cannot bypass RLS. Used by the Vercel read API.
SUPABASE_ANON_KEY=sb_publishable_xxx_or_legacy_anon_key

# Secret / service-role key — bypasses RLS (BYPASSRLS). Used ONLY by the
# ingest job (GitHub Actions). NEVER ship this to the iOS app or the API.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx_or_legacy_service_role_key

# Optional: cap how far back the backfill seeds (days). Defaults to 90.
BACKFILL_DAYS=90

# Optional: comma-separated price sources to ingest. Defaults to all three.
# Allowed: cardkingdom,tcgplayer,cardmarket
PRICE_SOURCES=cardkingdom,tcgplayer,cardmarket

# ── On-demand ingest trigger (Vercel API only) ──────────────────────────────
# Set on the Vercel read API so PUT /v1/owned can fire a GitHub
# repository_dispatch ("new-cards") and fetch new cards' prices ASAP. If unset,
# the API skips the dispatch and prices arrive via the daily cron instead.
# GH_DISPATCH_TOKEN: a FINE-GRAINED PAT scoped to this repo with
#   "Actions: read and write". This is NOT the Supabase service-role key.
# GH_REPO: the repo slug, "owner/name".
GH_DISPATCH_TOKEN=github_pat_xxx
GH_REPO=owner/ugins-vault-backend
